# ─── Local dev bypass ─────────────────────────────────────────────────────────
# Set to "true" to skip ALL token verification (JWE decrypt, JWT verify, ORC check).
# A warning is printed to stdout on every bypassed request.
# NEVER set this in production.
AUTH_BYPASS=false

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Connection string for your MongoDB instance.
# For a local Docker container: mongodb://localhost:27017/all-content
MONGODB_URL=mongodb://localhost:27017/all-content

# MongoDB connection pool size
POOL_SIZE=5

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
# Secret used to decrypt the outer JWE envelope (jose.jwtDecrypt).
# The raw string is SHA-256 hashed to produce the 256-bit AES key.
JOSE_SECRET=your-jose-secret-here

# Secret used to verify the inner signed JWT (jose.jwtVerify).
JWT_SIGNIN_PRIVATE_KEY=your-jwt-signin-private-key-here

# ─── External Service URLs ────────────────────────────────────────────────────
# Orchestration / auth service — validates that the token is still active.
# The guard POSTs { user_id } to this URL and checks the returned token.
ALL_ORC_SERVICE_URL=http://localhost:3009/v1/auth/token-status

# Language complexity API — appended with the language code (e.g. .../ta, .../hi).
# Called for ta, hi, te, kn content to compute wordMeasures, ortho/phonic complexity.
ALL_LC_API_URL=http://localhost:3010/v1/language-complexity/

# Text evaluation API — base URL; the service appends /getPhonemes or /getReadingComplexity.
# Called for English (phonemes) and hi/te/kn (reading complexity).
ALL_TEXT_EVAL_URL=http://localhost:3011/v1/

# ─── Server / Swagger ─────────────────────────────────────────────────────────
# Shown in the Swagger UI server dropdown. Defaults to http://localhost:3008.
SERVER_URL=http://localhost:3008

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Requests from unlisted origins are blocked.
# Leave empty to block all cross-origin requests (requests with no Origin header always pass).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
